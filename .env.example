# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma — pooled connection for app, direct for migrations
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Email
RESEND_API_KEY=re_xxx_your_key
RESEND_FROM_EMAIL=CheckFlow <noreply@yourdomain.com>

# Cron auth — Vercel Cron will pass this
CRON_SECRET=generate-a-long-random-string

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
